# Website Configuration
TARGET_URL=https://example.com/movie-page
ELEMENT_SELECTOR=.release-date

# Database Configuration
DATABASE_URL=postgres://mystery_user:your_password@postgres:5432/mystery_movie_db?sslmode=disable
POSTGRES_DB=mystery_movie_db
POSTGRES_USER=mystery_user
POSTGRES_PASSWORD=your_secure_password

# SMS Configuration (choose one)
# For Twilio:
SMS_API=twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890
PHONE_NUMBER=+1987654321

# Or for generic webhook:
# SMS_API=https://your-webhook-url.com/send-sms
# PHONE_NUMBER=+1987654321

# Optional
API_KEY=your_api_key_if_needed